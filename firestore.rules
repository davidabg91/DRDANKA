rules_version = '2';

// Firestore Security Rules for d-r-danka-nikolova HACCP system.
//
// Deploy with:  firebase deploy --only firestore:rules
//
// Identity model:
//   - Firebase Auth provides request.auth.token.email (verified email).
//   - The single admin is `d.nikolova.haccp@gmail.com`. Everyone else is a `user`.
//   - User documents live under /users/{email}; daily HACCP logs under /logs/{key}.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Lower-cased email so comparisons are case-insensitive.
    function authEmail() {
      return request.auth.token.email.lower();
    }

    function isAdmin() {
      return isSignedIn() && authEmail() == "d.nikolova.haccp@gmail.com";
    }

    // True when the post-update value of `field` is unchanged.
    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // /users/{email}
    //   - Admin: full read/write on every doc.
    //   - User: read & write own doc only (case-insensitive email match).
    //   - On create: doc id MUST equal the caller's email (no impersonation).
    //   - On update: a non-admin cannot escalate their own role or status.
    match /users/{email} {
      allow read: if isAdmin() || (isSignedIn() && authEmail() == email.lower());

      allow create: if isAdmin() || (
        isSignedIn() &&
        authEmail() == email.lower() &&
        request.resource.data.role == "user"
      );

      allow update: if isAdmin() || (
        isSignedIn() &&
        authEmail() == email.lower() &&
        unchanged("role") &&
        unchanged("status")
      );

      allow delete: if isAdmin();
    }

    // /logs/{key} — key format: danka_logs_<sanitizedEmail>_<YYYY-MM-DD>
    //   - Admin reads/writes everything (audit).
    //   - Authenticated user reads/writes own logs.
    //   NOTE: rules.String.replace uses REGEX patterns and replaces ALL matches,
    //   so '.' must be escaped as '\\.' to match a literal dot, not "any char".
    match /logs/{key} {
      function ownsKey() {
        return key.matches(
          "^danka_logs_" + authEmail().replace("@", "_").replace("\\.", "_") + "_.*$"
        );
      }

      allow read, write: if isAdmin() || (isSignedIn() && ownsKey());
    }

    // Audit trail of admin actions: append-only, admin-only.
    match /admin_audit/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
