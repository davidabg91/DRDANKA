rules_version = '2';

// Firestore Security Rules for d-r-danka-nikolova HACCP system.
//
// Deploy with:  firebase deploy --only firestore:rules
//
// Identity model:
//   - Firebase Auth provides request.auth.token.email (verified email).
//   - The single admin is `d.nikolova.haccp@gmail.com`. Everyone else is a `user`.
//   - User documents live under /users/{email}; daily HACCP logs under /logs/{key}.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Lower-cased email so comparisons are case-insensitive.
    function authEmail() {
      return request.auth.token.email.lower();
    }

    function sanitizeEmail(email) {
      return (email.split("@")[0].split("[.]").size() == 1 
        ? email.split("@")[0] 
        : (email.split("@")[0].split("[.]").size() == 2 
            ? email.split("@")[0].split("[.]")[0] + "_" + email.split("@")[0].split("[.]")[1] 
            : email.split("@")[0].split("[.]")[0] + "_" + email.split("@")[0].split("[.]")[1] + "_" + email.split("@")[0].split("[.]")[2])
      ) + "_" + (
        email.split("@")[1].split("[.]").size() == 2 
          ? email.split("@")[1].split("[.]")[0] + "_" + email.split("@")[1].split("[.]")[1] 
          : email.split("@")[1].split("[.]")[0] + "_" + email.split("@")[1].split("[.]")[1] + "_" + email.split("@")[1].split("[.]")[2]
      );
    }

    function isOwnerOfKey(key, email) {
      return key >= "danka_logs_" + sanitizeEmail(email) + "_reg_" && 
             key < "danka_logs_" + sanitizeEmail(email) + "_reg_~";
    }

    function isAdmin() {
      return isSignedIn() && authEmail() == "d.nikolova.haccp@gmail.com";
    }

    // True when the post-update value of `field` is unchanged.
    function unchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    // /users/{email}
    //   - Admin: full read/write on every doc.
    //   - User: read & write own doc only (case-insensitive email match).
    //   - On create: doc id MUST equal the caller's email (no impersonation).
    //   - On update: a non-admin cannot escalate their own role or status.
    match /users/{email} {
      allow read: if isAdmin() || (isSignedIn() && authEmail() == email.lower());

      allow create: if isAdmin() || (
        isSignedIn() &&
        authEmail() == email.lower() &&
        request.resource.data.role == "user"
      );

      allow update: if isAdmin() || (
        isSignedIn() &&
        authEmail() == email.lower() &&
        unchanged("role") &&
        unchanged("status") &&
        (unchanged("subscriptionFeeEur") || request.resource.data.subscriptionFeeEur in [50, 80, 120]) &&
        unchanged("purchasedCourseIds")
      );

      allow delete: if isAdmin();
    }

    // /logs/{key} — key format: danka_logs_<sanitizedEmail>_reg_<registerId>_<period>
    //   - Admin reads/writes everything (audit).
    //   - Authenticated user reads/writes own logs.
    match /logs/{key} {
      allow read, write: if isAdmin() || (isSignedIn() && isOwnerOfKey(key, authEmail()));
    }

    // Audit trail of admin actions: append-only, admin-only.
    match /admin_audit/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // /courses/{courseId} — digital bookstore catalog.
    //   - Public read: anyone can browse the catalog.
    //   - Write: admin only.
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // /purchases/{purchaseId} — paid orders.
    //   - Read/write: admin only. Buyers see their access via
    //     /users/{email}.purchasedCourseIds rather than reading /purchases.
    //   - The Firebase Admin SDK (server-side) bypasses these rules for
    //     post-checkout writes from /api/stripe/webhook.
    match /purchases/{purchaseId} {
      allow read, write: if isAdmin();
    }

    // /enrollments/{id} — public training enrollments (anonymous signups
    // from /training). Anyone can submit; admin reviews and contacts them.
    match /enrollments/{id} {
      allow create: if true;          // public signup form
      allow read, update, delete: if isAdmin();
    }

    // /trainings/{id} — specialized online courses catalog.
    //   - Public read: anyone can browse from /training.
    //   - Write: admin only.
    match /trainings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // /priceOverrides/{slug} — admin-controlled price overrides for
    // code-curated catalog items. Public read so /library and /live can
    // show the latest price without a server roundtrip. Admin-only write.
    match /priceOverrides/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
