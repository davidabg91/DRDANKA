rules_version = '2';

// Firebase Storage Rules for the digital bookstore.
//
// Storage Rules cross-check Firestore to verify the caller actually owns the
// course before letting them download the PDF. This means the viewer can use
// `getDownloadURL()` directly from the client, with no Firebase Admin SDK or
// API route required.

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == "d.nikolova.haccp@gmail.com";
    }

    // Check the buyer's /users/{email}.purchasedCourseIds for the courseId.
    function hasPurchased(courseId) {
      let email = request.auth.token.email.lower();
      let userPath = /databases/(default)/documents/users/$(email);
      return request.auth != null
        && firestore.exists(userPath)
        && courseId in firestore.get(userPath).data.purchasedCourseIds;
    }

    match /courses/{courseId}/{fileName} {
      // Public read for cover images. PDF read requires admin OR purchaser.
      allow read: if fileName.matches('^cover\\..+')
        || (fileName == 'file.pdf' && (isAdmin() || hasPurchased(courseId)));

      // Admin uploads — separate size/type limits per file kind.
      allow write: if isAdmin() && (
        (fileName == 'file.pdf'
          && request.resource.size < 200 * 1024 * 1024
          && request.resource.contentType == 'application/pdf')
        ||
        (fileName.matches('^cover\\..+')
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*'))
      );
    }

    // Cover images for specialized trainings (catalog imagery).
    // Public read, admin write only. Same naming scheme: cover.<ext>.
    match /trainings/{trainingId}/{fileName} {
      allow read: if fileName.matches('^cover\\..+');
      allow write: if isAdmin()
        && fileName.matches('^cover\\..+')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Library materials (code-based catalog at src/data/library/).
    // Each material's PDF lives at library/<slug>/file.pdf and is readable
    // only by admin OR a buyer who has the slug in purchasedCourseIds.
    function hasPurchasedSlug(slug) {
      let email = request.auth.token.email.lower();
      let userPath = /databases/(default)/documents/users/$(email);
      return request.auth != null
        && firestore.exists(userPath)
        && slug in firestore.get(userPath).data.purchasedCourseIds;
    }

    match /library/{slug}/file.pdf {
      allow read: if isAdmin() || hasPurchasedSlug(slug);
      allow write: if isAdmin()
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }
  }
}
